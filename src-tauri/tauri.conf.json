{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "NexusPad",
  "version": "0.9.2",
  "identifier": "com.nexuspad.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "./ui/dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NexusPad",
        "width": 420,
        "height": 386,
        "resizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": [
      "nsis",
      "deb"
    ],
    "active": true
  }
}